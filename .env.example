GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

GEMINI_MODEL=gemini-3.1-pro-preview
OPENAI_MODEL=gpt-5.5
CLAUDE_MODEL=claude-opus-4-8

# Optional local Gemma settings
GEMMA_BACKEND=transformers
GEMMA_MODEL=google/gemma-4-31B-it
GEMMA_DEVICE_MAP=auto
GEMMA_TORCH_DTYPE=auto
GEMMA_TEXT_SINGLE_MAX_CHARS=220000
GEMMA_TEXT_CHUNK_CHARS=220000
GEMMA_TEXT_MIN_CHUNK_CHARS=10000
HF_TOKEN=

# Optional Ollama settings if GEMMA_BACKEND=ollama
OLLAMA_BASE_URL=http://localhost:11434
